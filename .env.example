# ============================================================
# EventFlow - Environment Configuration
# Copy this file to .env and fill in your real values
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=replace_with_local_db_password
DB_NAME=eventflow

# ── JWT Secret (generate a strong random key for production) ─
JWT_SECRET=replace_with_64_plus_character_random_secret

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_LINK_TOKEN_TTL_MINUTES=10

# ── Email (Gmail SMTP) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_username
MAIL_PASSWORD=replace_with_smtp_app_password
