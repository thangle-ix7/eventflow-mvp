# ============================================================
# EventFlow - Environment Configuration
# Copy this file to .env and fill in your real values
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=replace_with_local_db_password
DB_NAME=eventflow

# ── JWT Secret (generate a strong random key for production) ─
JWT_SECRET=replace_with_64_plus_character_random_secret

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_LINK_TOKEN_TTL_MINUTES=10

# ── Email (Vietnix Business Email SMTP) ─────────────────────
MAIL_HOST=mail49.vietnix.vn
MAIL_PORT=465
MAIL_USERNAME=noreply@eventflow.vn
MAIL_PASSWORD=replace_with_noreply_mailbox_password
MAIL_FROM=noreply@eventflow.vn
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

# ── Auth Security ────────────────────────────────────────────
APP_FRONTEND_URL=http://localhost:5173
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_REQUIRE_EMAIL_DELIVERY=false

# ── API Security ────────────────────────────────────────────
OPENAPI_SERVER_URL=http://localhost:8080
AUDIT_LOGGING_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_READ_PER_MINUTE=300
RATE_LIMIT_WRITE_PER_MINUTE=120
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
ABUSE_PROTECTION_ENABLED=true
ABUSE_MAX_URI_LENGTH=2048
ABUSE_MAX_QUERY_LENGTH=4096
ABUSE_MAX_HEADER_LENGTH=8192
ABUSE_MAX_CONTENT_LENGTH_BYTES=1048576

# ── Supabase Storage (server-side S3 credentials) ────────────
# Enable this after creating a bucket and S3 access key in Supabase Storage.
SUPABASE_STORAGE_ENABLED=false
SUPABASE_STORAGE_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=ap-southeast-1
SUPABASE_STORAGE_ACCESS_KEY=replace_with_supabase_s3_access_key
SUPABASE_STORAGE_SECRET_KEY=replace_with_supabase_s3_secret_key
SUPABASE_STORAGE_BUCKET=eventflow-storage

# ── AI Assistant (Groq OpenAI-compatible API) ────────────────
AI_API_KEY=replace_with_groq_api_key
AI_MODEL_NAME=llama-3.3-70b-versatile
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_ASSISTANT_OPENAI_ENABLED=true

# ── Frontend Analytics (Mixpanel public project token) ───────
VITE_MIXPANEL_TOKEN=replace_with_mixpanel_project_token
