# ============================================================
# EventFlow - Environment Configuration
# Copy this file to .env and fill in your real values
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=replace_with_local_db_password
DB_NAME=eventflow

# ── JWT Secret (generate a strong random key for production) ─
JWT_SECRET=replace_with_64_plus_character_random_secret

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_LINK_TOKEN_TTL_MINUTES=10

# ── Email (Gmail SMTP) ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_username
MAIL_PASSWORD=replace_with_smtp_app_password
MAIL_FROM=replace_with_sender_email

# ── Auth Security ────────────────────────────────────────────
APP_FRONTEND_URL=http://localhost:5173
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_REQUIRE_EMAIL_DELIVERY=false
