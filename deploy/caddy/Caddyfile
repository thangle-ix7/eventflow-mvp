{
	email {$ACME_EMAIL}
}

{$PROD_DOMAIN} {
	encode zstd gzip

	handle /actuator* {
		respond 404
	}

	handle /api-docs* {
		respond 404
	}

	handle /v3/api-docs* {
		respond 404
	}

	handle /swagger-ui* {
		respond 404
	}

	handle /swagger-ui.html {
		respond 404
	}

	handle /api/* {
		reverse_proxy backend-prod:8080
	}

	handle {
		reverse_proxy frontend-prod:80
	}
}

{$STAGING_DOMAIN} {
	encode zstd gzip

	basic_auth {
		{$STAGING_BASIC_AUTH_USER} {$STAGING_BASIC_AUTH_HASH}
	}

	handle /api/* {
		reverse_proxy backend-staging:8080
	}

	handle /api/webhooks/* {
		reverse_proxy backend-staging:8080
	}

	handle {
		reverse_proxy frontend-staging:80
	}
}
