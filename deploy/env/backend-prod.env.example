DB_USERNAME=eventflow_prod
DB_PASSWORD=replace_with_strong_prod_db_password

JWT_SECRET=replace_with_64_plus_character_random_secret
JWT_EXPIRATION_MS=86400000

APP_FRONTEND_URL=https://event-flow.example.com
OPENAPI_SERVER_URL=https://event-flow.example.com
AUTH_REQUIRE_EMAIL_DELIVERY=true
EVENTFLOW_SECURITY_CORS_ALLOWED_ORIGINS=https://event-flow.example.com,https://www.event-flow.example.com
EVENTFLOW_SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=

TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_LINK_TOKEN_TTL_MINUTES=10

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_username
MAIL_PASSWORD=replace_with_smtp_app_password
MAIL_FROM=replace_with_sender_email

AUDIT_LOGGING_ENABLED=true
MANAGEMENT_HEALTH_MAIL_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_READ_PER_MINUTE=240
RATE_LIMIT_WRITE_PER_MINUTE=80
RATE_LIMIT_WEBHOOK_PER_MINUTE=60
ABUSE_PROTECTION_ENABLED=true
ABUSE_MAX_CONTENT_LENGTH_BYTES=10485760

SUPABASE_STORAGE_ENABLED=true
SUPABASE_STORAGE_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=ap-southeast-1
SUPABASE_STORAGE_ACCESS_KEY=replace_with_supabase_s3_access_key
SUPABASE_STORAGE_SECRET_KEY=replace_with_supabase_s3_secret_key
SUPABASE_STORAGE_BUCKET=eventflow-storage

AI_API_KEY=replace_with_groq_or_openai_compatible_api_key
AI_MODEL_NAME=llama-3.3-70b-versatile
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_ASSISTANT_OPENAI_ENABLED=true
