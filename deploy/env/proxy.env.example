ACME_EMAIL=admin@example.com
PROD_DOMAIN=event-flow.example.com
STAGING_DOMAIN=staging.event-flow.example.com

# Frontend build-time bot usernames. Keep each environment on its own bot.
PROD_TELEGRAM_BOT_USERNAME=eventflow_mvp_bot
STAGING_TELEGRAM_BOT_USERNAME=Eventflow_vn_bot

# Generate with:
# docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'replace_with_strong_password'
STAGING_BASIC_AUTH_USER=eventflow-admin
STAGING_BASIC_AUTH_HASH=replace_with_caddy_bcrypt_hash
